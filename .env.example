# Polymarket bot configuration
# Copy this file to .env and fill in your values

# Your Polygon wallet private key (hex string, with or without leading 0x)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Your Polygon wallet public address
WALLET_ADDRESS=0xYOUR_WALLET_ADDRESS_HERE

# USDC amount to risk per trade
BET_SIZE_USDC=1.0

# Set to "false" to place real orders (default is dry-run)
DRY_RUN=true
